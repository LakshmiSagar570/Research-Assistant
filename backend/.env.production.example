# Copy this file's contents into Vercel's Environment Variables UI for the
# BACKEND project (Settings -> Environment Variables). Do NOT commit a real
# .env.production file with actual secrets to git.

# --- Required ---

# From Supabase: Project Settings -> Database -> Connection string -> URI
# (choose "Connection pooling" / Transaction mode if available - serverless
# functions open many short-lived connections, and Supabase's pooler
# (pgbouncer) handles that far better than a direct connection).
# It will look like: postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:5432/postgres

# Generate a real random secret, e.g. locally run:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Never reuse the placeholder value from local dev.
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_HEX_STRING

# Marks this deployment as production: disables demo user seeding,
# hides /docs, enables HSTS header, enforces the JWT_SECRET check above.
ENV=production

# Must NOT be true in production.
SEED_DEMO_USER=false

# Comma-separated list is not supported directly by pydantic-settings list
# parsing from a single env var by default; instead set this as a JSON
# array string, matching what Vercel's env var UI accepts:
CORS_ORIGINS=["https://YOUR-FRONTEND-PROJECT.vercel.app"]

# --- Optional (defaults are usually fine) ---
# ACCESS_TOKEN_EXPIRE_MINUTES=720
# LOGIN_RATE_LIMIT=10/minute
# REGISTER_RATE_LIMIT=5/minute
